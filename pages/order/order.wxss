/* pages/order/order.wxss */
.wrap {
  padding: 40rpx;
  background: #f6f6f6;
  min-height: 100vh;
}
.page-title {
  font-size: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  color: #222;
}
/* 顶部标签 */
.tab-wrap {
  display: flex;
  width: 100%;
  margin-bottom: 40rpx;
  gap: 20rpx;
}
.tab-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #fff;
  border-radius: 10rpx;
  font-size: 30rpx;
  color: #666;
}
/* 选中高亮 */
.tab-item.active {
  background: #ff7800;
  color: #fff;
}
.empty-tip {
  text-align: center;
  font-size: 32rpx;
  color: #999;
  margin-top: 200rpx;
}
.order-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 35rpx;
  margin-bottom: 30rpx;
}
.row {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}
.label {
  width: 180rpx;
  color: #666;
}
.val {
  flex: 1;
  color: #333;
}
.price {
  color: #f53f3f;
  font-weight: 500;
}
.status {
  color: #07c160;
}