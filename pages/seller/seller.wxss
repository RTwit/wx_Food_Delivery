/* pages/seller/seller.wxss */
.wrap {
  background: #f6f6f6;
  min-height: 100vh;
  padding: 30rpx 16rpx;
  box-sizing: border-box;
}

/* 页面标题 */
.page-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #222;
  display: block;
  margin-bottom: 30rpx;
}

/* 搜索栏 */
.search-box {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}
.search-input {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}
button {
  width: 180rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 500;
}
button::after {
  border: none;
  border-radius: 12rpx;
}

/* 加载/空提示 */
.loading-tip, .empty-tip {
  text-align: center;
  font-size: 30rpx;
  color: #999;
  padding: 120rpx 0;
}

/* 商家卡片 */
.seller-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  gap: 20rpx;
}
.seller-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.seller-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.seller-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #111;
  margin-bottom: 12rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.text-tip {
  font-size: 26rpx;
  color: #666;
}
.text-tip--bold {
  color: #ff4d00;
  font-weight: bold;
}