<!--pages/sellerDet/sellerDet.wxml-->
<view class="wrap">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 商家内容 -->
  <view wx:elif="{{detailInfo.id}}">
    <view class="img-wrap">
      <image class="detail-img" src="{{baseUrl}}{{detailInfo.imgUrl}}" mode="aspectFill" binderror="imgError"/>
      <view class="collect-btn" bind:tap="chgCollect">
        <text wx:if="{{isCollect}}">已收藏</text>
        <text wx:else>收藏商家</text>
      </view>
    </view>

    <!-- 商家信息 -->
    <view class="info-box">
      <text class="shop-name">{{detailInfo.name}}</text>
      <view class="desc">商家简介：{{detailInfo.introduction}}</view>
      <view class="row">
        <text>评分：</text>
        <text class="score">{{detailInfo.score}}分</text>
      </view>
      <view class="row">
        <text>人均：¥{{detailInfo.avgCost}}</text>
        <text>月售{{detailInfo.saleQuantity}}</text>
      </view>
      <view class="row">
        <text>配送距离：{{detailInfo.distance}}m</text>
        <text>配送时长：{{detailInfo.deliveryTime}}分钟</text>
      </view>
      <view class="address">门店地址：{{detailInfo.address}}</view>
    </view>

    <!-- 菜品分类 -->
    <scroll-view scroll-x class="tab-scroll">
      <view class="tab-item {{curCatId == item.id ? 'active' : ''}}" 
            wx:for="{{catList}}" 
            wx:key="id"
            bind:tap="switchCat"
            data-cid="{{item.id}}">
        {{item.name}}
      </view>
    </scroll-view>

    <!-- 菜品列表 -->
    <view class="product-list">
      <view class="product-item" wx:for="{{prodList}}" wx:key="id">
        <image class="pro-img" src="{{baseUrl}}{{item.imgUrl}}" mode="aspectFill" binderror="imgError"/>
        <view class="pro-info">
          <text class="pro-name">{{item.name}}</text>
          <text class="pro-price">¥{{item.price}}</text>
          <text class="pro-desc">{{item.detail}}</text>
          <text class="pro-sales">月销{{item.saleQuantity}}</text>
        </view>
        <view class="pro-actions">
          <view class="qty-btn minus" bind:tap="decreaseQty" data-id="{{item.id}}" wx:if="{{item.qty > 0}}">-</view>
          <text class="qty-num" wx:if="{{item.qty > 0}}">{{item.qty}}</text>
          <view class="qty-btn plus" bind:tap="increaseQty" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </view>
  </view>
  <!-- 用户评价区域 -->
  <view class="comment-wrap">
    <view class="comment-header">
      <view class="comment-title">用户评价（{{totComment}}条）</view>
      <view class="to-comment" bind:tap="toComment">去评论> </view>
    </view>

    <!-- 循环渲染单条评论 -->
    <block wx:for="{{commentList}}" wx:key="id">
      <view class="comment-item">
        <view class="user-row">
          <image class="avatar" src="{{baseUrl}}{{item.avatar}}" mode="aspectFill"></image>
          <text class="nick">{{item.nickName}}</text>
        </view>
        <view class="comment-text">{{item.content}}</view>
        <view class="comment-time">{{item.commentDate}}</view>
        <!-- 商家回复 -->
        <view wx:if="{{item.replyContent}}" class="seller-reply">
          <text>商家回复：{{item.replyContent}} {{item.replyTime}}</text>
        </view>
        <view class="like-text">点赞 {{item.likeNum}}</view>
      </view>
    </block>

    <!-- 无评论空状态 -->
    <view wx:if="{{commentList.length === 0}}" class="empty-tip">
      暂无用户评价
    </view>
  </view>
</view>

<!-- 底部购物车 -->
<view class="cart-bar">
  <view class="cart-left" bind:tap="toCart">
    <view class="cart-icon">
      <text>🛒</text>
      <view class="cart-badge" wx:if="{{cartTotalNum > 0}}">{{cartTotalNum}}</view>
    </view>
    <text class="cart-text">购物车</text>
  </view>
  <view class="cart-right">
    <text class="total-price">¥{{cartTotalPrice}}</text>
    <button class="checkout-btn" bind:tap="toCart" disabled="{{cartTotalNum === 0}}">去结算</button>
  </view>
</view>