/* pages/sellerDet/sellerDet.wxss */
.wrap {
  background: #f6f6f6;
  min-height: 100vh;
}
.img-wrap {
  position: relative;
  width: 100%;
}
.detail-img {
  width: 100%;
  height: 320rpx;
}
.collect-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: rgba(255,255,255,0.8);
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #f43f3b;
}
.info-box {
  background: #fff;
  margin: 20rpx 16rpx;
  border-radius: 12rpx;
  padding: 30rpx;
}
.shop-name {
  font-size: 38rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #555;
  margin-bottom: 16rpx;
}
.score {
  color: orangered;
}
.desc, .address {
  font-size: 28rpx;
  color: #666;
  margin-top: 20rpx;
  line-height: 1.6;
}
.loading {
  text-align: center;
  padding-top: 200rpx;
  font-size: 30rpx;
  color: #999;
}
/* 分类横向 */
.tab-scroll {
  background: #fff;
  white-space: nowrap;
  padding: 0 20rpx;
}
.tab-item {
  display: inline-block;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: #666;
}
.tab-item.active {
  color: #ff4500;
  border-bottom: 4rpx solid #ff4500;
}

/* 菜品列表 */
.product-list {
  padding: 20rpx;
}
.product-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  gap: 20rpx;
}
.pro-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.pro-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.pro-name {
  font-size: 32rpx;
  color: #111;
}
.pro-price {
  font-size: 30rpx;
  color: #ff4500;
  margin: 8rpx 0;
}
.pro-desc, .pro-sales {
  font-size: 24rpx;
  color: #888;
}
/* 评论列表 */
.comment-wrap {
  margin: 30rpx 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
}
.comment-title {
  font-size: 34rpx;
  font-weight: bold;
}
.comment-header{
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom:30rpx;
}
.go-comment{
  font-size:30rpx;
  color:#ff6700;
}
.comment-item {
  border-bottom: 1rpx #eee solid;
  padding: 25rpx 0;
}
.user-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
}
.nick {
  font-size: 30rpx;
  color: #222;
}
.star-row {
  color: #ffb800;
  font-size: 28rpx;
}
.comment-text {
  font-size: 30rpx;
  margin: 15rpx 0;
  color: #333;
}
.comment-time {
  font-size: 24rpx;
  color: #999;
}
.seller-reply {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f6f6f6;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}
.like-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #777;
}
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #aaa;
}