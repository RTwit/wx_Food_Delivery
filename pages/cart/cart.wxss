/* pages/cart/cart.wxss */
.cart-page {
  background: #f6f6f6;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 空状态 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 36rpx;
  color: #333;
  margin-bottom: 16rpx;
}
.empty-tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.go-shopping-btn {
  background: #ff7800;
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}
.go-shopping-btn::after {
  border: 0;
}

/* 商家头部 */
.seller-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}
.seller-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.clear-btn {
  font-size: 28rpx;
  color: #999;
}

/* 商品列表 */
.cart-list {
  background: #fff;
  margin-top: 20rpx;
}
.cart-item {
  display: flex;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: center;
}
.cart-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.cart-info {
  flex: 1;
  padding: 0 20rpx;
  display: flex;
  flex-direction: column;
}
.cart-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}
.cart-price {
  font-size: 30rpx;
  color: #f43f3b;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.cart-detail {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  flex-shrink: 0;
}
.subtotal {
  font-size: 30rpx;
  color: #f43f3b;
  font-weight: bold;
}

/* 数量控制 */
.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}
.qty-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  border: 2rpx solid #ddd;
}
.qty-btn.plus {
  background: #ff7800;
  color: #fff;
  border-color: #ff7800;
}
.qty-btn.minus {
  background: #fff;
  color: #333;
}
.qty-num {
  font-size: 32rpx;
  color: #333;
  width: 50rpx;
  text-align: center;
  font-weight: bold;
}

/* 底部结算栏 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
}
.footer-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.total-label {
  font-size: 28rpx;
  color: #666;
}
.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #f43f3b;
}
.total-count {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}
.checkout-btn {
  background: #ff7800;
  color: #fff;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}
.checkout-btn::after {
  border: 0;
}