<!--pages/cart/cart.wxml-->
<view class="cart-page">
  <!-- 空状态 -->
  <view wx:if="{{cartItems.length === 0}}" class="empty-cart">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <text class="empty-tip">快去选购心仪的美食吧</text>
    <button class="go-shopping-btn" bind:tap="goShopping">去选购</button>
  </view>

  <!-- 有商品状态 -->
  <view wx:else>
    <!-- 商家信息 -->
    <view class="seller-header">
      <text class="seller-name">{{cartData.sellerName}}</text>
      <text class="clear-btn" bind:tap="clearCart">清空购物车</text>
    </view>

    <!-- 商品列表 -->
    <view class="cart-list">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
        <image class="cart-img" src="{{baseUrl}}{{item.imgUrl}}" mode="aspectFill" lazy-load loading="lazy" />
        <view class="cart-info">
          <text class="cart-name">{{item.name}}</text>
          <text class="cart-price">¥{{item.price}}</text>
          <text class="cart-detail">{{item.detail}}</text>
        </view>
        <view class="cart-right">
          <view class="qty-control">
            <view class="qty-btn minus" bind:tap="decreaseQty" data-id="{{item.id}}">-</view>
            <text class="qty-num">{{item.qty}}</text>
            <view class="qty-btn plus" bind:tap="increaseQty" data-id="{{item.id}}">+</view>
          </view>
          <text class="subtotal">¥{{item.subtotal}}</text>
        </view>
      </view>
    </view>

    <!-- 底部结算栏 -->
    <view class="cart-footer">
      <view class="footer-left">
        <text class="total-label">合计：</text>
        <text class="total-price">¥{{cartTotalPrice}}</text>
        <text class="total-count">共{{cartTotalNum}}件</text>
      </view>
      <button class="checkout-btn" bind:tap="checkout">去结算</button>
    </view>
  </view>
</view>