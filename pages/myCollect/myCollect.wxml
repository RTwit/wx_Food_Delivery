<!--pages/myCollect/myCollect.wxml-->
<view wx:if="{{list.length == 0}}" class="empty">
  <text>暂无收藏店铺</text>
</view>
<view wx:else class="collect-list">
  <view wx:for="{{list}}" wx:key="id" class="collect-item">
    <!-- 店铺图片 -->
    <image src="{{baseUrl}}{{item.imgUrl}}" mode="aspectFill" class="shop-img" lazy-load loading="lazy"></image>
    <view class="shop-info">
      <text class="shop-name">{{item.sellerName}}</text>
      <text class="shop-tip">{{item.score}}分 | 月售{{item.saleQuantity}}</text>
      <text class="shop-address">{{item.address}}</text>
    </view>
    <button bind:tap="cancCollect" data-id="{{item.id}}" size="mini" type="warn">取消收藏</button>
  </view>
</view>