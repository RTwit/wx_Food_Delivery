/* pages/feedback/feedback.wxss */
.wrap{
  padding:40rpx 50rpx;
}

.title{
  font-size:40rpx;
  text-align:center;
  margin-bottom:60rpx;
}

.input-box{
  border-bottom:1rpx #eee solid;
  padding:30rpx 0;
}

.label
{font-size:32rpx;
  color:#333;
  display:block;
  margin-bottom:20rpx;
}

textarea{
  width:100%;
  height:200rpx;
  border:1rpx #eee solid;
  padding:20rpx;
  box-sizing:border-box;
  font-size:30rpx;
}

.submit-btn{
  margin-top:80rpx;
  background:#07c160;
  color:#fff;
  border-radius:10rpx;
}

.list-tip{
  text-align:center;
  margin-top:40rpx;
  color:#07c160;
  font-size:30rpx;
}