<!--pages/home/home.wxml-->
<view class="container">
  <!-- 橙色顶部导航栏 -->
  <view class="top-header">
    <view class="header-row">
      <view class="header-left">首页</view>
      <view class="header-location" bind:tap="getLocation">
        <text>当前定位：{{location}}</text>
      </view>
    </view>
    <!-- 搜索框 -->
    <view class="search-wrap">
      <input class="search-input" placeholder="搜索菜品、商家" bindinput="onSearchInput" value="{{keyword}}" bindblur="onSearchBlur"/>
      <button bind:tap="onSearchTap" class="search-btn">搜索</button>
    </view>
  </view>
  <!-- 轮播图 -->
  <swiper class="ads-swiper" wx:if="{{!isSearching && ads.length > 0 }}" indicator-dots autoplay interval="3000" indicator-active-color="red" indicator-color="white" circular>
    <swiper-item wx:for="{{ads}}" wx:key="id">
      <image
        class="ads-img"
        src="{{baseUrl}}{{item.advImg}}"
        mode="aspectFill"
        data-item="{{item}}"
        bind:tap="toAdsTap"
        style="width: 100%;"
        lazy-load
        loading="lazy"
      />
    </swiper-item>
  </swiper>

  <!-- 主题分类 -->
  <view class="theme-section" wx:if="{{!isSearching && themeList.length > 0 }} " >
    <scroll-view scroll-x class="theme-scroll">
      <view class="theme-item" wx:for="{{themeList}}" wx:key="id" data-theme="{{item}}" bind:tap="toThemeTap">
        <image class="theme-icon" src="{{baseUrl}}{{item.imgUrl}}" mode="aspectFill" lazy-load loading="lazy" />
        <text class="theme-name">{{item.themeName}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 搜索结果或附近商家 -->
  <view class="sticky-title-wrap">
  <view class="title-row">
    <text class="section-title">{{isSearching ? '搜索结果' : '附近商家'}}</text>
    <text class="more-btn" wx:if="{{!isSearching}}" bind:tap="toSeller">更多 ></text>
  </view>
</view>
  <view class="seller-section">
    <view wx:if="{{sellerList.length === 0 && !loading}}" class="empty-state">
      <text>暂无商家</text>
    </view>
    <view class="seller-list">
      <view class="seller-card card"
        wx:for="{{sellerList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bind:tap="toSellerDet"
      >
        <image class="seller-img" src="{{baseUrl}}{{item.imgUrl}}" mode="aspectFill" binderror="imgError"
        data-index="{{index}}" lazy-load loading="lazy" 
        placeholder="/images/pic-default.png" />
      <view class="seller-img-placeholder" wx:if="{{!item.imgUrl}}"></view>
        <view class="seller-info">
          <text class="seller-name text-name">{{item.name}}</text>
          <view class="seller-meta">
            <text class="text-tip">人均 ¥{{item.avgCost}} | 月售{{item.saleQuantity}}</text>
          </view>
          <view class="seller-meta">
            <text class="text-tip">{{item.distance}}m | {{item.deliveryTime}}分钟</text>
          </view>
          <view class="seller-meta">
            <text class="text-tip text-tip--bold">{{item.score}}分</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-more">加载中...</view>
  </view>
</view>
