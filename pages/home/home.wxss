/* pages/home/home.wxss */
/* 外卖首页样式 */
.container {
  width: 100%;
  padding-top: 24rpx;
  box-sizing: border-box;
}
/* 头部样式 */
.top-header {
  background-color: #ff7800;
  padding: calc(var(--status-bar-height) + 20rpx) 30rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
}
.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.header-left {
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 500;
}
.header-location {
  /* display: flex;
  align-items: center; */
  font-size: 28rpx;
  color: #fff;
}
/* 搜索框 */
.search-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 999rpx;
  padding: 18rpx 30rpx;
  margin: 10rpx 16rpx;
  width: 94%;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}
button.search-btn {
  background: #fff;
  color: #000;
  background-color: #ff7800;
  font-size: 28rpx;
  padding: 14rpx 40rpx;
  border-radius: 999rpx;
  border: none;
  margin: 0;
  white-space: nowrap;
}
/* 清除button自带边框伪元素 */
button.search-btn::after {
  border: 0;
}
.search-placeholder {
  /* margin-left: 12rpx; */
  font-size: 26rpx;
  color: #999;
}
/* 轮播 */
.ads-swiper {
  width: 100%;
  height: 280rpx;
  margin: 0 0 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.ads-img {
  width: 100%;
  height: 100%;
}
/* 主题分类 */
.theme-section {
  margin-bottom: 32rpx;
}

.theme-scroll {
  white-space: nowrap;
  padding: 0 16rpx;
  height: 180rpx;
}

.theme-item {
  display: inline-block;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin: 0 20rpx;
  width: 120rpx;
  vertical-align: top;
}

.theme-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.theme-name {
  font-size: 24rpx;
  color: #595959;
  text-align: center;
}
/* 商家区域 */
.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #1D1D1D;
  padding: 0 16rpx;
  margin-bottom: 24rpx;
}
.sticky-title-wrap {
  position: sticky;
  top: 0; /* 滑到页面顶部时固定 */
  background: #ffffff;
  z-index: 99; /* 层级高于列表，不会被盖住 */
  padding: 20rpx 0;
}

.seller-card {
  display: flex;
  flex-direction: row;
  margin: 0 0 16rpx;
  height: 200rpx;
  padding: 16rpx;
  border-radius: 0;
  background: #fff;
}

.seller-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.seller-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.seller-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-tip{
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 30rpx 0;
}
.text-tip--bold {
  font-weight: bold;
  color: orangered;
}

.loading-more {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 30rpx 0;
}

.empty-state, .loading-more {
  padding: 0 16rpx;
}