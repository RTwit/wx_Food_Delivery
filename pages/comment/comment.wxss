/* pages/comment/comment.wxss */
.form-container {
  padding: 40rpx 30rpx;
}
.star-box {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  gap: 30rpx;
}
.label {
  font-size: 32rpx;
  white-space: nowrap;
}
.star-group {
  display: flex;
  gap: 16rpx;
}
.star {
  font-size: 50rpx;
  color: #ddd;
}
.star.active {
  color: #ffb800;
}
.input-area {
  width: 100%;
  height: 300rpx;
  border: 1rpx #eee solid;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}
.submit-btn {
  margin-top: 50rpx;
  background: #ff6700;
  color: #fff;
  border-radius: 50rpx;
}