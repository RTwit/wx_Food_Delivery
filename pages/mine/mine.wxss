/* pages/mine/mine.wxss */
/* 个人中心页样式 */
.mine-page {
  min-height: 100vh;
}

.user-header {
  height: 240rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  background: #F2F2F2;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1D1D1D;
}

.order-status {
  margin: 0 32rpx 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1D1D1D;
  margin-bottom: 24rpx;
}

.order-grid {
  display: flex;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.order-label {
  font-size: 24rpx;
  color: #595959;
}

.menu-list {
  margin: 0 32rpx 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 96rpx;
  font-size: 30rpx;
  color: #1D1D1D;
  border-bottom: 2rpx solid #F7F8FA;
}

.menu-item:last-child {
  border-bottom: none;
}

.logout-section {
  padding: 48rpx 32rpx;
}