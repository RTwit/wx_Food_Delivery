<!--pages/feedList/feedList.wxml-->
<view class="wrap">
  <view class="title">我的反馈记录</view>
  <block wx:if="{{feedList.length === 0}}">
    <view class="empty">暂无反馈记录</view>
  </block>
  <block wx:else>
    <view class="feed-item" wx:for="{{feedList}}" wx:key="id" bind:tap="toDetail" data-id="{{item.id}}">
      <view class="item-title">{{item.title}}</view>
      <view class="item-content">{{item.content}}</view>
      <text class="arrow">></text>
    </view>
  </block>
</view>