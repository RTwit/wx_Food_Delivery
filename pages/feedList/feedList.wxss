/* pages/feedList/feedList.wxss */
.wrap{
  padding:40rpx;
}

.title{
  font-size:40rpx;
  text-align:center;
  margin-bottom:50rpx;
}

.empty{
  text-align:center;
  color:#999;
  font-size:32rpx;
  margin-top:200rpx;
}

.feed-item{
  display:flex;
  justify-content:space-between;
  align-items:center;
  border-bottom:1rpx #eee solid;
  padding:30rpx 0;
}

.item-title{
  font-size:34rpx;
  color:#222;
}

.item-content{
  font-size:28rpx;
  color:#777;
  margin-top:10rpx;
}
