/* pages/changePwd/changePwd.wxss */

.page-wrap {
  padding: 50rpx 40rpx;
}
.page-title {
  font-size: 40rpx;
  text-align: center;
  margin-bottom: 60rpx;
}
.form-item {
  display: flex;
  align-items: center;
  border-bottom: 1rpx #eee solid;
  height: 95rpx;
  font-size: 32rpx;
}
.label {
  width: 180rpx;
  color: #555;
}
.form-item input {
  flex: 1;
  height: 80rpx;
}
.submit-btn {
  margin-top: 100rpx;
  background: #07c160;
  color: #fff;
  border-radius: 10rpx;
}